<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.29.xsd">

    <!-- Fully native Liquibase changeTypes throughout - no raw <sql>, so the changelog stays
         database-portable rather than tied to MariaDB syntax. One consequence: native Liquibase
         XML has no changeType for arbitrary CHECK expressions on any database, so the JSON
         validity checks (CHECK(json_valid(...))) and the tinyint ordinal-enum range checks that
         MariaDB previously enforced at the DB layer are intentionally NOT recreated here -
         enforcement of those is now an application/Hibernate-layer concern only. -->

    <changeSet id="create-tenants" author="blackhole">
        <comment>Baseline: tenants table</comment>
        <createTable tableName="tenants">
            <column name="identifier" type="uuid">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="meta_data" type="json"/>
            <column name="name" type="varchar(255)"/>
            <column name="slug" type="varchar(255)">
                <constraints unique="true" uniqueConstraintName="UKkn82rs0p55luybrg4n7x7di8"/>
            </column>
            <column name="status" type="tinyint"/>
        </createTable>
    </changeSet>

    <changeSet id="create-punishment-templates" author="blackhole">
        <comment>Baseline: punishment_templates table (elo_delta folded in from the former V8 migration)</comment>
        <createTable tableName="punishment_templates">
            <column name="identifier" type="uuid">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="meta_data" type="json"/>
            <column name="reason" type="varchar(255)"/>
            <column name="tenant_id" type="uuid"/>
            <column name="type" type="tinyint"/>
            <column name="elo_delta" type="int" defaultValueNumeric="0">
                <constraints nullable="false"/>
            </column>
        </createTable>
    </changeSet>

    <changeSet id="constraints-punishment-templates" author="blackhole">
        <createIndex indexName="IDXfb0n1048swedl734iua11xgh6" tableName="punishment_templates">
            <column name="identifier"/>
        </createIndex>
        <createIndex indexName="IDX6sna77t8blfhbf7vw1d949qv7" tableName="punishment_templates">
            <column name="tenant_id"/>
        </createIndex>
    </changeSet>

    <changeSet id="create-punishments" author="blackhole">
        <comment>Baseline: punishments table</comment>
        <createTable tableName="punishments">
            <column name="identifier" type="varchar(255)">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="meta_data" type="json"/>
            <column name="scope" type="varchar(255)"/>
            <column name="source" type="uuid"/>
            <column name="tenant_id" type="uuid"/>
            <column name="type" type="tinyint"/>
            <column name="template_identifier" type="uuid"/>
        </createTable>
    </changeSet>

    <changeSet id="constraints-punishments" author="blackhole">
        <createIndex indexName="IDXbg1863u12hbsiqggy1kxv84gj" tableName="punishments">
            <column name="identifier"/>
        </createIndex>
        <createIndex indexName="IDXf248pwm8h4gskq8r86ohne5bd" tableName="punishments">
            <column name="tenant_id"/>
        </createIndex>
        <addForeignKeyConstraint constraintName="FKsystxtartkbg3pelwij5y444y"
                                  baseTableName="punishments" baseColumnNames="template_identifier"
                                  referencedTableName="punishment_templates" referencedColumnNames="identifier"/>
    </changeSet>

    <changeSet id="create-punishment-profiles" author="blackhole">
        <comment>Baseline: punishment_profiles table</comment>
        <createTable tableName="punishment_profiles">
            <column name="owner" type="varchar(255)">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="tenant_id" type="uuid">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="meta_data" type="json"/>
            <column name="active_ban_identifier" type="varchar(255)">
                <constraints unique="true" uniqueConstraintName="UKjenhq1urh55q6qbhxbor43mpr"/>
            </column>
            <column name="active_chat_ban_identifier" type="varchar(255)">
                <constraints unique="true" uniqueConstraintName="UK3bfpsh5gh8uybcnqn6ist0ju3"/>
            </column>
        </createTable>
    </changeSet>

    <changeSet id="constraints-punishment-profiles" author="blackhole">
        <createIndex indexName="IDXs2rqilyfwjja2eh18bvdkgssg" tableName="punishment_profiles">
            <column name="owner"/>
        </createIndex>
        <addForeignKeyConstraint constraintName="FK44vycpq38twfwo4pm864edwtf"
                                  baseTableName="punishment_profiles" baseColumnNames="active_chat_ban_identifier"
                                  referencedTableName="punishments" referencedColumnNames="identifier"/>
        <addForeignKeyConstraint constraintName="FKrg26gk6cng7up213jiux4ugap"
                                  baseTableName="punishment_profiles" baseColumnNames="active_ban_identifier"
                                  referencedTableName="punishments" referencedColumnNames="identifier"/>
    </changeSet>

    <changeSet id="create-punishment-profiles-punishments" author="blackhole">
        <comment>Baseline: punishment_profiles_punishments join table</comment>
        <createTable tableName="punishment_profiles_punishments">
            <column name="punishment_profile_entity_owner" type="varchar(255)">
                <constraints nullable="false"/>
            </column>
            <column name="punishment_profile_entity_tenant_id" type="uuid">
                <constraints nullable="false"/>
            </column>
            <column name="history_identifier" type="varchar(255)">
                <constraints nullable="false" unique="true" uniqueConstraintName="UK72hdqv4fhab29f7yg9a80d1nt"/>
            </column>
        </createTable>
    </changeSet>

    <changeSet id="constraints-punishment-profiles-punishments" author="blackhole">
        <addForeignKeyConstraint constraintName="FK7yf2av2hp2nfq84philn3588l"
                                  baseTableName="punishment_profiles_punishments" baseColumnNames="history_identifier"
                                  referencedTableName="punishments" referencedColumnNames="identifier"/>
        <addForeignKeyConstraint constraintName="FKrwhtrufbtcfrxgociysp1d1iw"
                                  baseTableName="punishment_profiles_punishments"
                                  baseColumnNames="punishment_profile_entity_owner,punishment_profile_entity_tenant_id"
                                  referencedTableName="punishment_profiles" referencedColumnNames="owner,tenant_id"/>
    </changeSet>

    <changeSet id="create-punishment-evidence" author="blackhole">
        <comment>Evidence attached to a punishment</comment>
        <createTable tableName="punishment_evidence">
            <column name="identifier" type="uuid">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="captured_content_hash" type="varchar(255)"/>
            <column name="evidence_type" type="tinyint"/>
            <column name="meta_data" type="json"/>
            <column name="reference_id" type="varchar(255)"/>
            <column name="retention_expires_at" type="bigint"/>
            <column name="tenant_id" type="uuid"/>
            <column name="punishment_identifier" type="varchar(255)"/>
        </createTable>
    </changeSet>

    <changeSet id="constraints-punishment-evidence" author="blackhole">
        <createIndex indexName="IDXeowdvehtn2mq9ratnjjt10mx0" tableName="punishment_evidence">
            <column name="identifier"/>
        </createIndex>
        <createIndex indexName="IDX88plc6lylknnkler3ds0vmagv" tableName="punishment_evidence">
            <column name="tenant_id"/>
        </createIndex>
        <addForeignKeyConstraint constraintName="FK1fcfw3b9ah8l5ywj1ksemk98r"
                                  baseTableName="punishment_evidence" baseColumnNames="punishment_identifier"
                                  referencedTableName="punishments" referencedColumnNames="identifier"/>
    </changeSet>

    <changeSet id="create-reports" author="blackhole">
        <comment>Player reports</comment>
        <createTable tableName="reports">
            <column name="identifier" type="uuid">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="category" type="tinyint"/>
            <column name="created_at" type="bigint">
                <constraints nullable="false"/>
            </column>
            <column name="description" type="varchar(1000)"/>
            <column name="meta_data" type="json"/>
            <column name="reported_hash" type="varchar(255)"/>
            <column name="reporter_hash" type="varchar(255)"/>
            <column name="resolution_note" type="varchar(1000)"/>
            <column name="resolved_by" type="uuid"/>
            <column name="status" type="tinyint"/>
            <column name="tenant_id" type="uuid"/>
            <column name="updated_at" type="bigint">
                <constraints nullable="false"/>
            </column>
        </createTable>
    </changeSet>

    <changeSet id="constraints-reports" author="blackhole">
        <createIndex indexName="IDXcdecaabcx0057rmwougq4lln8" tableName="reports">
            <column name="identifier"/>
        </createIndex>
        <createIndex indexName="IDXp2ffpn85f33jnlh9a6dw6dfjd" tableName="reports">
            <column name="tenant_id"/>
        </createIndex>
        <createIndex indexName="IDXhucb8heess4o7s9d641njq2e0" tableName="reports">
            <column name="reporter_hash"/>
        </createIndex>
    </changeSet>

    <changeSet id="create-report-evidence-references" author="blackhole">
        <comment>Report-to-evidence reference join table</comment>
        <createTable tableName="report_evidence_references">
            <column name="report_identifier" type="uuid">
                <constraints nullable="false"/>
            </column>
            <column name="evidence_identifier" type="uuid"/>
        </createTable>
    </changeSet>

    <changeSet id="constraints-report-evidence-references" author="blackhole">
        <addForeignKeyConstraint constraintName="FK27b8gnu183fwcp3f8ixk9xw49"
                                  baseTableName="report_evidence_references" baseColumnNames="report_identifier"
                                  referencedTableName="reports" referencedColumnNames="identifier"/>
    </changeSet>

    <changeSet id="create-connector-registrations" author="blackhole">
        <comment>Connector registrations</comment>
        <createTable tableName="connector_registrations">
            <column name="identifier" type="uuid">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="meta_data" type="json"/>
            <column name="name" type="varchar(255)"/>
            <column name="oauth2_client_id" type="varchar(255)">
                <constraints unique="true" uniqueConstraintName="UKhb72u55ks7duissu086wfgjd4"/>
            </column>
            <column name="oauth2_client_secret_hash" type="varchar(255)"/>
            <column name="status" type="tinyint"/>
            <column name="tenant_id" type="uuid"/>
        </createTable>
    </changeSet>

    <changeSet id="constraints-connector-registrations" author="blackhole">
        <createIndex indexName="IDXp64mq4clkp3b1d9c6jmo06021" tableName="connector_registrations">
            <column name="identifier"/>
        </createIndex>
        <createIndex indexName="IDXhwsvcq9wogcnjafm8qmil9niy" tableName="connector_registrations">
            <column name="tenant_id"/>
        </createIndex>
    </changeSet>

    <changeSet id="create-connector-scopes" author="blackhole">
        <comment>Connector OAuth2 scopes</comment>
        <createTable tableName="connector_scopes">
            <column name="connector_identifier" type="uuid">
                <constraints nullable="false"/>
            </column>
            <column name="scope" type="varchar(255)"/>
        </createTable>
    </changeSet>

    <changeSet id="constraints-connector-scopes" author="blackhole">
        <addForeignKeyConstraint constraintName="FK2w8vnnh1hjq9qy8dgny2uwgbt"
                                  baseTableName="connector_scopes" baseColumnNames="connector_identifier"
                                  referencedTableName="connector_registrations" referencedColumnNames="identifier"/>
    </changeSet>

    <changeSet id="create-event-subscriptions" author="blackhole">
        <comment>Connector event subscriptions</comment>
        <createTable tableName="event_subscriptions">
            <column name="identifier" type="uuid">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="active" type="boolean">
                <constraints nullable="false"/>
            </column>
            <column name="delivery_url" type="varchar(255)"/>
            <column name="failure_count" type="int">
                <constraints nullable="false"/>
            </column>
            <column name="last_attempt_at" type="bigint"/>
            <column name="last_success_at" type="bigint"/>
            <column name="meta_data" type="json"/>
            <column name="signing_secret" type="varchar(255)"/>
            <column name="connector_identifier" type="uuid"/>
        </createTable>
    </changeSet>

    <changeSet id="constraints-event-subscriptions" author="blackhole">
        <createIndex indexName="IDX4ja81yhw8rl240tcyebtjgvx4" tableName="event_subscriptions">
            <column name="identifier"/>
        </createIndex>
        <addForeignKeyConstraint constraintName="FKsp913s457jgefhadxb9p06qyo"
                                  baseTableName="event_subscriptions" baseColumnNames="connector_identifier"
                                  referencedTableName="connector_registrations" referencedColumnNames="identifier"/>
    </changeSet>

    <changeSet id="create-event-subscription-types" author="blackhole">
        <comment>Event subscription type join table</comment>
        <createTable tableName="event_subscription_types">
            <column name="subscription_identifier" type="uuid">
                <constraints nullable="false"/>
            </column>
            <column name="event_type" type="varchar(255)"/>
        </createTable>
    </changeSet>

    <changeSet id="constraints-event-subscription-types" author="blackhole">
        <addForeignKeyConstraint constraintName="FKrtito3r91kmi2qej9acwox35h"
                                  baseTableName="event_subscription_types" baseColumnNames="subscription_identifier"
                                  referencedTableName="event_subscriptions" referencedColumnNames="identifier"/>
    </changeSet>

    <changeSet id="create-elo-profiles" author="blackhole">
        <comment>Dual-ELO profile per player/tenant</comment>
        <createTable tableName="elo_profiles">
            <column name="owner" type="varchar(255)">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="tenant_id" type="uuid">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="chat_elo" type="int">
                <constraints nullable="false"/>
            </column>
            <column name="chat_elo_updated_at" type="bigint">
                <constraints nullable="false"/>
            </column>
            <column name="gameplay_elo" type="int">
                <constraints nullable="false"/>
            </column>
            <column name="gameplay_elo_updated_at" type="bigint">
                <constraints nullable="false"/>
            </column>
            <column name="meta_data" type="json"/>
        </createTable>
    </changeSet>

    <changeSet id="constraints-elo-profiles" author="blackhole">
        <createIndex indexName="IDX5k6jltfkea67v5ai92cey03u7" tableName="elo_profiles">
            <column name="owner"/>
        </createIndex>
    </changeSet>

    <changeSet id="create-elo-events" author="blackhole">
        <comment>Append-only Elo audit trail</comment>
        <createTable tableName="elo_events">
            <column name="identifier" type="uuid">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="created_at" type="bigint">
                <constraints nullable="false"/>
            </column>
            <column name="delta" type="int">
                <constraints nullable="false"/>
            </column>
            <column name="meta_data" type="json"/>
            <column name="owner" type="varchar(255)"/>
            <column name="reason_code" type="tinyint"/>
            <column name="resulting_score" type="int">
                <constraints nullable="false"/>
            </column>
            <column name="source_evidence_id" type="uuid"/>
            <column name="tenant_id" type="uuid"/>
            <column name="track" type="tinyint"/>
        </createTable>
    </changeSet>

    <changeSet id="constraints-elo-events" author="blackhole">
        <createIndex indexName="IDX1vli9egxhskmxh09x7ippe01p" tableName="elo_events">
            <column name="identifier"/>
        </createIndex>
        <createIndex indexName="IDXbi03h5v8mngaibmc7f6eo81s3" tableName="elo_events">
            <column name="tenant_id"/>
        </createIndex>
        <createIndex indexName="IDX8kfktno2r37fryp23hbrywxge" tableName="elo_events">
            <column name="owner"/>
        </createIndex>
    </changeSet>

    <changeSet id="create-appeals" author="blackhole">
        <comment>Appeal workflow</comment>
        <createTable tableName="appeals">
            <column name="identifier" type="uuid">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="appellant_hash" type="varchar(255)"/>
            <column name="created_at" type="bigint">
                <constraints nullable="false"/>
            </column>
            <column name="decided_by" type="uuid"/>
            <column name="decision_note" type="varchar(2000)"/>
            <column name="eligibility_check_result" type="json"/>
            <column name="meta_data" type="json"/>
            <column name="statement" type="varchar(2000)"/>
            <column name="status" type="tinyint"/>
            <column name="tenant_id" type="uuid"/>
            <column name="updated_at" type="bigint">
                <constraints nullable="false"/>
            </column>
            <column name="punishment_identifier" type="varchar(255)"/>
        </createTable>
    </changeSet>

    <changeSet id="constraints-appeals" author="blackhole">
        <createIndex indexName="IDXkumdsu9qt44a38mg4k9ngyp87" tableName="appeals">
            <column name="identifier"/>
        </createIndex>
        <createIndex indexName="IDX7yn6lv2wptlia206ij210jtig" tableName="appeals">
            <column name="tenant_id"/>
        </createIndex>
        <createIndex indexName="IDX9faypy3gxh4xmiqii41ypsj5k" tableName="appeals">
            <column name="appellant_hash"/>
        </createIndex>
        <addForeignKeyConstraint constraintName="FKqb76lk2ldlufmeevnpme8l94m"
                                  baseTableName="appeals" baseColumnNames="punishment_identifier"
                                  referencedTableName="punishments" referencedColumnNames="identifier"/>
    </changeSet>

    <changeSet id="create-ip-correlation-tokens" author="blackhole">
        <comment>Ban-evasion detection via hashed IP correlation</comment>
        <createTable tableName="ip_correlation_tokens">
            <column name="identifier" type="uuid">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="first_seen" type="bigint">
                <constraints nullable="false"/>
            </column>
            <column name="last_seen" type="bigint">
                <constraints nullable="false"/>
            </column>
            <column name="meta_data" type="json"/>
            <column name="occurrence_count" type="int">
                <constraints nullable="false"/>
            </column>
            <column name="owner_hash" type="varchar(255)"/>
            <column name="tenant_id" type="uuid"/>
            <column name="token" type="varchar(255)"/>
        </createTable>
    </changeSet>

    <changeSet id="constraints-ip-correlation-tokens" author="blackhole">
        <createIndex indexName="IDXej580909u0b2cronpaairkgty" tableName="ip_correlation_tokens">
            <column name="identifier"/>
        </createIndex>
        <createIndex indexName="IDXb4n6xf0005sm3973m6oyxrw1t" tableName="ip_correlation_tokens">
            <column name="tenant_id"/>
        </createIndex>
        <createIndex indexName="IDXdchy5i8x4p42k38necseou23o" tableName="ip_correlation_tokens">
            <column name="token"/>
        </createIndex>
    </changeSet>

    <changeSet id="create-tenant-elo-settings" author="blackhole">
        <comment>Per-tenant Elo settings</comment>
        <createTable tableName="tenant_elo_settings">
            <column name="tenant_id" type="uuid">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="base_elo_chat" type="int"/>
            <column name="base_elo_gameplay" type="int"/>
            <column name="perma_ban_template_chat_id" type="uuid"/>
            <column name="perma_ban_template_gameplay_id" type="uuid"/>
            <column name="perma_ban_threshold_chat" type="int"/>
            <column name="perma_ban_threshold_gameplay" type="int"/>
            <column name="report_reward_delta" type="int"/>
        </createTable>
    </changeSet>

</databaseChangeLog>
